RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
AGENT_QUEUE=agent_tasks
BACKEND_CALLBACK_URL=http://host.docker.internal:8800/api/v1/callback/
AGENT_API_KEY=change-me

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local model, runs natively on host for Metal/GPU acceleration)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b

PRODUCTION=false
PROMPT_VERSION=v2

# LangFuse (self-hosted, optional)
# LANGFUSE_HOST=http://localhost:3500
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# Sentry (production only, optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
