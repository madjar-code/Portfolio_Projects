# Root .dockerignore — used by nginx/Dockerfile (context: .)
# Only frontend/ and nginx/ are needed for the build.

agent/
backend/
architecture/
docs/
.git/
.github/
Makefile
*.md

# frontend transient artefacts
frontend/node_modules/
frontend/dist/
frontend/.env*

**/__pycache__/
**/*.py[cod]
**/.venv/
**/*.log
**/.env
**/.env.*
