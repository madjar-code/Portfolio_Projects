{
  "title": "API (RED)",
  "uid": "backend-api",
  "schemaVersion": 38,
  "timezone": "browser",
  "time": {"from": "now-30m", "to": "now"},
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by view",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "targets": [{
        "expr": "sum by (view) (rate(django_http_requests_total_by_view_transport_method_total[1m]))",
        "legendFormat": "{{view}}",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency p95 by view",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (view, le) (rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])))",
        "legendFormat": "p95 {{view}}",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p99 by view",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by (view, le) (rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])))",
        "legendFormat": "p99 {{view}}",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "5xx rate (last 5m)",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
      "targets": [{
        "expr": "sum(rate(django_http_responses_total_by_status_view_method_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_view_method_total[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 3}}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DB query p95",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 6},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(django_db_query_duration_seconds_bucket[5m])))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}}
    }
  ]
}